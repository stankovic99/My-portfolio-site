---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { frontmatter } = Astro.props;
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{frontmatter.title} | Stefan Stankovic</title>
  </head>
  <body class="bg-[#040D14] text-white min-h-screen font-sans selection:bg-[#00E5CC] selection:text-black">
    <Navbar />

    <main class="pt-32 pb-20 max-w-4xl mx-auto px-6 md:px-12">
      
      <div class="mb-12">
        <a href="/portfolio" class="inline-flex items-center gap-2 text-gray-400 hover:text-[#00E5CC] transition-colors font-mono text-sm uppercase tracking-widest">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Back to Portfolio
        </a>
      </div>

      <div class="mb-10 border-b border-gray-800 pb-10">
        <div class="flex items-center gap-3 mb-4">
          <span class="font-mono text-xs uppercase tracking-widest text-[#00E5CC]">{frontmatter.category}</span>
          <span class="h-1 w-1 rounded-full bg-gray-700"></span>
          <span class="font-mono text-xs text-gray-500">{frontmatter.date}</span>
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-sans font-extrabold tracking-tight text-white mb-6">
          {frontmatter.title}
        </h1>
        
        <p class="text-xl text-gray-400 leading-relaxed mb-8">
          {frontmatter.description}
        </p>

        {frontmatter.liveLink && (
          <a href={frontmatter.liveLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-sm border border-transparent bg-[#00E5CC] px-6 py-3 text-sm font-bold uppercase tracking-[0.18em] text-[#040D14] shadow-[0_0_30px_rgba(0,229,204,0.14)] transition duration-300 hover:-translate-y-0.5 hover:bg-white hover:shadow-[0_0_35px_rgba(255,255,255,0.18)]">
            View Live Website
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
          </a>
        )}
      </div>

      <article class="prose prose-invert prose-teal max-w-none prose-headings:font-sans prose-headings:font-bold prose-a:text-[#00E5CC] prose-img:rounded-2xl">
        <slot />
      </article>

    </main>
    <Footer />
  </body>
</html>