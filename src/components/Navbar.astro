---
// src/components/Navbar.astro
// Pravilan import slike iz src foldera (putanja je relativna u odnosu na komponentu)
import logo from '../images/logo.svg';
---

<nav class="w-full bg-[#040D14]/95 backdrop-blur-md border-b border-gray-800 text-white fixed top-0 z-50">
  <!-- Smanjili smo py-5 na py-3 da navbar bude elegantniji i uži -->
  <div class="max-w-7xl mx-auto px-6 md:px-12 py-3 flex justify-between items-center">
    
    <!-- Logo - centriran, definisana visina da ne lomi navbar -->
    <a href="/" class="z-50 flex items-center justify-center">
      <img src={logo.src} alt="Stefan Stankovic Logo" class="h-8 md:h-10 w-auto object-contain" />
    </a>

    <!-- Navigacioni Linkovi (Desktop) -->
    <div class="hidden md:flex space-x-8 text-sm font-sans font-semibold uppercase tracking-widest text-gray-300 items-center">
      <a href="/" class="hover:text-[#00E5CC] transition-colors duration-200">Home</a>
      <a href="/about" class="hover:text-[#00E5CC] transition-colors duration-200">About</a>
      <a href="/portfolio" class="hover:text-[#00E5CC] transition-colors duration-200">Portfolio</a>
      <a href="/services" class="hover:text-[#00E5CC] transition-colors duration-200">Services</a>
    </div>

    <!-- CTA Dugme -->
    <a href="/contact" class="hidden md:inline-flex items-center justify-center bg-[#00E5CC] text-[#040D14] hover:bg-white px-6 py-2.5 rounded-sm text-sm font-bold uppercase tracking-wider transition-all duration-300">
      CONTACT
    </a>

    <!-- Mobilni meni ikonica -->
    <button id="mobile-menu-btn" class="md:hidden text-gray-300 hover:text-[#00E5CC] focus:outline-none z-50">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <!-- Padajući meni za mobilne -->
  <div id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-[#040D14] border-b border-gray-800 flex-col items-center py-8 space-y-6 shadow-2xl">
    <a href="/" class="mobile-link text-gray-300 hover:text-[#00E5CC] text-lg font-bold uppercase tracking-widest">Home</a>
    <a href="/about" class="mobile-link text-gray-300 hover:text-[#00E5CC] text-lg font-bold uppercase tracking-widest">About</a>
    <a href="/portfolio" class="mobile-link text-gray-300 hover:text-[#00E5CC] text-lg font-bold uppercase tracking-widest">Portfolio</a>
    <a href="/services" class="mobile-link text-gray-300 hover:text-[#00E5CC] text-lg font-bold uppercase tracking-widest">Services</a>
    <a href="/contact" class="mobile-link bg-[#00E5CC] text-[#040D14] px-10 py-3.5 rounded-sm font-bold uppercase tracking-wider mt-4">CONTACT</a>
  </div>
</nav>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const links = document.querySelectorAll('.mobile-link');

    if (btn && menu) {
      btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
        menu.classList.toggle('flex');
      });
    }

    links.forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        menu.classList.remove('flex');
      });
    });
  });
</script>