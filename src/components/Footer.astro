---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-800 bg-[#040D14] pt-12 md:pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    
    <div class="grid grid-cols-2 md:grid-cols-12 gap-x-4 gap-y-10 md:gap-8 mb-12 md:mb-16">
      
      <div class="col-span-2 md:col-span-12 lg:col-span-6 flex flex-col items-start">
        <a href="/" class="inline-block text-2xl font-sans font-black tracking-tighter text-white mb-4 hover:text-[#00E5CC] transition-colors">
          STEFAN<span class="text-[#00E5CC]">.</span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed font-mono max-w-sm">
          Bridging enterprise architecture with high-performance modern web. Building scalable systems with zero code bloat.
        </p>
      </div>

      <div class="col-span-1 md:col-span-6 lg:col-span-3 flex flex-col items-start">
        <h3 class="text-white font-bold tracking-widest text-xs uppercase mb-5 font-mono">Navigation</h3>
        <ul class="flex flex-col gap-3 items-start w-full">
          <li><a href="/" class="text-sm text-gray-400 hover:text-[#00E5CC] transition-colors">Home</a></li>
          <li><a href="/about" class="text-sm text-gray-400 hover:text-[#00E5CC] transition-colors">About</a></li>
          <li><a href="/services" class="text-sm text-gray-400 hover:text-[#00E5CC] transition-colors">Services</a></li>
          <li><a href="/portfolio" class="text-sm text-gray-400 hover:text-[#00E5CC] transition-colors">Portfolio & Blog</a></li>
          <li><a href="/contact" class="text-sm text-gray-400 hover:text-[#00E5CC] transition-colors">Contact</a></li>
        </ul>
      </div>

      <div class="col-span-1 md:col-span-6 lg:col-span-3 flex flex-col items-start">
        <h3 class="text-white font-bold tracking-widest text-xs uppercase mb-5 font-mono">Connect</h3>
        <ul class="flex flex-col gap-3 items-start w-full">
          <li><a href="mailto:stefan.stankovicc99@gmail.com" class="text-sm text-gray-400 hover:text-[#00E5CC] transition-colors">Email Me</a></li>
          <li><a href="#" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 hover:text-[#00E5CC] transition-colors">LinkedIn</a></li>
          <li><a href="#" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 hover:text-[#00E5CC] transition-colors">GitHub</a></li>
        </ul>
      </div>

    </div>

    <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-gray-500 font-mono uppercase tracking-widest text-center md:text-left">
        &copy; {currentYear} Stefan Stankovic. All rights reserved.
      </p>
      
      <p class="hidden md:flex text-xs text-gray-500 font-mono uppercase tracking-widest items-center justify-center gap-2">
        <span class="h-1.5 w-1.5 rounded-full bg-[#00E5CC]"></span>
        Skopje, North Macedonia
      </p>
    </div>
    
  </div>
</footer>