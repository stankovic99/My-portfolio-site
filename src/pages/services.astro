---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';

const pageTitle = "Stefan Stankovic | Services";
const pageDescription = "Core services designed to scale enterprise workflows and connect data.";
---

<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
  </head>
  <body class="bg-[#040D14] text-white min-h-screen font-sans selection:bg-[#00E5CC] selection:text-black">
    <Navbar />

    <main class="pt-32">
      <!-- HERO -->
      <section class="container-custom pb-20">
        <div class="text-center lg:text-left max-w-4xl mx-auto lg:mx-0 fade-in-up">
          <span class="pill-badge">Service Line</span>
          <h1 class="heading-page">
            Build modern systems with a clear technical backbone.
          </h1>
          <p class="text-body max-w-3xl">
            A vertical timeline of core services designed to scale enterprise workflows, connect data, and keep product experiences fast, polished, and reliable.
          </p>
        </div>
      </section>

      <!-- TIMELINE -->
      <section class="max-w-5xl mx-auto px-4 md:px-8 relative pb-20 overflow-x-hidden">
            
            <div class="absolute left-[27px] md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-[#00E5CC]/50 to-transparent md:-translate-x-1/2 z-0"></div>

            <div class="space-y-12 relative z-10">
                
                <article class="reveal-on-scroll opacity-0 translate-y-10 transition-all duration-1000 ease-out relative flex flex-col gap-4 pl-16 md:pl-0 md:flex-row">
                    <div class="absolute top-6 z-10 flex items-center justify-center rounded-full shadow-[0_0_15px_rgba(0,229,204,0.4)] h-5 w-5 border-2 border-[#040D14] bg-[#00E5CC] left-[11px] transform -translate-x-1/2 md:left-1/2 md:-translate-x-1/2 md:border-4">
                    </div>
                    
                    <div class="md:w-[calc(50%-3rem)] md:text-right flex justify-end relative z-10">
                        <div class="w-full rounded-3xl border border-gray-800 bg-[#0a1520] p-6 md:p-8 shadow-xl transition-all hover:border-[#00E5CC]/50 hover:shadow-[0_0_35px_rgba(0,229,204,0.1)]">
                            <span class="font-mono text-xs uppercase tracking-[0.2em] text-[#00E5CC] mb-2 block">Enterprise</span>
                            <h3 class="text-2xl font-bold text-white mb-1">Dynamics 365 F&O Architecture</h3>
                            <p class="text-sm font-mono text-gray-400 mb-4">Senior Technical Architect</p>
                            <p class="text-gray-300 leading-relaxed mb-6 text-sm md:text-base">Deep technical expertise in Microsoft Dynamics 365 F&O and X++. I build scalable, highly optimized enterprise resource planning systems tailored to complex business logic.</p>
                            <div class="flex flex-wrap gap-2 md:justify-end">
                                <span class="tag">D365 F&O</span><span class="tag">X++</span><span class="tag">ERP</span>
                            </div>
                        </div>
                    </div>
                    <div class="hidden md:block md:w-[calc(50%-3rem)]"></div>
                </article>

                <article class="reveal-on-scroll opacity-0 translate-y-10 transition-all duration-1000 ease-out relative flex flex-col gap-4 pl-16 md:pl-0 md:flex-row-reverse">
                    <div class="absolute top-6 z-10 flex items-center justify-center rounded-full shadow-[0_0_15px_rgba(0,229,204,0.4)] h-5 w-5 border-2 border-[#040D14] bg-[#00E5CC] left-[11px] transform -translate-x-1/2 md:left-1/2 md:-translate-x-1/2 md:border-4">
                    </div>
                    
                    <div class="md:w-[calc(50%-3rem)] flex justify-start relative z-10">
                        <div class="w-full rounded-3xl border border-gray-800 bg-[#0a1520] p-6 md:p-8 shadow-xl transition-all hover:border-[#00E5CC]/50 hover:shadow-[0_0_35px_rgba(0,229,204,0.1)]">
                            <span class="font-mono text-xs uppercase tracking-[0.2em] text-[#00E5CC] mb-2 block">Automation</span>
                            <h3 class="text-2xl font-bold text-white mb-1">Power Platform Solutions</h3>
                            <p class="text-sm font-mono text-gray-400 mb-4">Certified Pro (PL-900 1000/1000)</p>
                            <p class="text-gray-300 leading-relaxed mb-6 text-sm md:text-base">Orchestrating seamless business workflows using Power Automate and custom connectors. Turning manual, disconnected processes into automated, zero-touch pipelines.</p>
                            <div class="flex flex-wrap gap-2 justify-start">
                                <span class="tag">Power Platform</span><span class="tag">Automate</span><span class="tag">Integrations</span>
                            </div>
                        </div>
                    </div>
                    <div class="hidden md:block md:w-[calc(50%-3rem)]"></div>
                </article>

                <article class="reveal-on-scroll opacity-0 translate-y-10 transition-all duration-1000 ease-out relative flex flex-col gap-4 pl-16 md:pl-0 md:flex-row">
                    <div class="absolute top-6 z-10 flex items-center justify-center rounded-full shadow-[0_0_15px_rgba(0,229,204,0.4)] h-5 w-5 border-2 border-[#040D14] bg-[#00E5CC] left-[11px] transform -translate-x-1/2 md:left-1/2 md:-translate-x-1/2 md:border-4">
                    </div>
                    
                    <div class="md:w-[calc(50%-3rem)] md:text-right flex justify-end relative z-10">
                        <div class="w-full rounded-3xl border border-gray-800 bg-[#0a1520] p-6 md:p-8 shadow-xl transition-all hover:border-[#00E5CC]/50 hover:shadow-[0_0_35px_rgba(0,229,204,0.1)]">
                            <span class="font-mono text-xs uppercase tracking-[0.2em] text-[#00E5CC] mb-2 block">Frontend</span>
                            <h3 class="text-2xl font-bold text-white mb-1">Web Experiences</h3>
                            <p class="text-sm font-mono text-gray-400 mb-4">Full-Stack Development</p>
                            <p class="text-gray-300 leading-relaxed mb-6 text-sm md:text-base">Building ultra-fast, minimalist frontends using Astro, Tailwind CSS, and Webflow. Bridging the gap between heavy enterprise backends and lightning-fast user experiences.</p>
                            <div class="flex flex-wrap gap-2 md:justify-end">
                                <span class="tag">Astro</span><span class="tag">Tailwind</span><span class="tag">Webflow</span>
                            </div>
                        </div>
                    </div>
                    <div class="hidden md:block md:w-[calc(50%-3rem)]"></div>
                </article>

                <article class="reveal-on-scroll opacity-0 translate-y-10 transition-all duration-1000 ease-out relative flex flex-col gap-4 pl-16 md:pl-0 md:flex-row-reverse">
                    <div class="absolute top-6 z-10 flex items-center justify-center rounded-full shadow-[0_0_15px_rgba(0,229,204,0.4)] h-5 w-5 border-2 border-[#040D14] bg-[#00E5CC] left-[11px] transform -translate-x-1/2 md:left-1/2 md:-translate-x-1/2 md:border-4">
                    </div>
                    
                    <div class="md:w-[calc(50%-3rem)] flex justify-start relative z-10">
                        <div class="w-full rounded-3xl border border-gray-800 bg-[#0a1520] p-6 md:p-8 shadow-xl transition-all hover:border-[#00E5CC]/50 hover:shadow-[0_0_35px_rgba(0,229,204,0.1)]">
                            <span class="font-mono text-xs uppercase tracking-[0.2em] text-[#00E5CC] mb-2 block">Consulting</span>
                            <h3 class="text-2xl font-bold text-white mb-1">Technical Strategy</h3>
                            <p class="text-sm font-mono text-gray-400 mb-4">Season Tech Agency</p>
                            <p class="text-gray-300 leading-relaxed mb-6 text-sm md:text-base">Guiding digital transformation. I translate chaotic business requirements into clear technical architecture, ensuring your infrastructure scales efficiently without bloat.</p>
                            <div class="flex flex-wrap gap-2 justify-start">
                                <span class="tag">Tech Lead</span><span class="tag">System Design</span><span class="tag">Architecture</span>
                            </div>
                        </div>
                    </div>
                    <div class="hidden md:block md:w-[calc(50%-3rem)]"></div>
                </article>

            </div>
        </section>
    </main>

    <Footer />
    
    <script src="../scripts/scrollReveal.js"></script>
  </body>
</html>