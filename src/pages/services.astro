---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';

const pageTitle = "Stefan Stankovic | Services";
const pageDescription = "Core services designed to scale enterprise workflows and connect data.";
---

<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
  </head>
  <body class="bg-[#040D14] text-white min-h-screen font-sans selection:bg-[#00E5CC] selection:text-black">
    <Navbar />

    <main class="pt-32">
      <!-- HERO -->
      <section class="container-custom pb-20">
        <div class="text-center lg:text-left max-w-4xl mx-auto lg:mx-0 fade-in-up">
          <span class="pill-badge">Service Line</span>
          <h1 class="heading-page">
            What I bring to the table.
          </h1>
          <p class="text-body max-w-3xl">
            I don't try to be a "jack-of-all-trades." I focus strictly on the technologies where I can deliver top-tier engineering. Here is what I can build for you, and what to expect if we partner up.
        </div>
      </section>

      <!-- TIMELINE -->
      <section class="max-w-5xl mx-auto px-4 md:px-8 relative pb-20 overflow-x-hidden">
            
            <div class="absolute left-[27px] md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-[#00E5CC]/50 to-transparent md:-translate-x-1/2 z-0"></div>

            <div class="space-y-12 relative z-10">
                
                <article class="reveal-on-scroll opacity-0 translate-y-10 transition-all duration-1000 ease-out relative flex flex-col gap-4 pl-16 md:pl-0 md:flex-row">
                    <div class="absolute top-6 z-10 flex items-center justify-center rounded-full shadow-[0_0_15px_rgba(0,229,204,0.4)] h-5 w-5 border-2 border-[#040D14] bg-[#00E5CC] left-[11px] transform -translate-x-1/2 md:left-1/2 md:-translate-x-1/2 md:border-4">
                    </div>
                    
                    <div class="md:w-[calc(50%-3rem)] md:text-right flex justify-end relative z-10">
                        <div class="w-full rounded-3xl border border-gray-800 bg-[#0a1520] p-6 md:p-8 shadow-xl transition-all hover:border-[#00E5CC]/50 hover:shadow-[0_0_35px_rgba(0,229,204,0.1)]">
                            <span class="font-mono text-xs uppercase tracking-[0.2em] text-[#00E5CC] mb-2 block">ENTERPRISE LOGIC</span>
                            <h3 class="text-2xl font-bold text-white mb-1">Dynamics 365 F&O Architecture</h3>
                            <p class="text-sm font-mono text-gray-400 mb-4">Intermediate Technical Consultant</p>
                            <p class="text-gray-300 leading-relaxed mb-6 text-sm md:text-base">This is my day-to-day engine. I write robust X++ business logic, execute complex data migrations, and customize modules for large-scale enterprise environments. If your ERP system needs stable, scalable customizations that won't break during Microsoft updates, this is where I come in.</p>
                            <div class="flex flex-wrap gap-2 md:justify-end">
                                <span class="tag">D365 F&O</span><span class="tag">X++</span><span class="tag">ERP</span>
                            </div>
                        </div>
                    </div>
                    <div class="hidden md:block md:w-[calc(50%-3rem)]"></div>
                </article>

                <article class="reveal-on-scroll opacity-0 translate-y-10 transition-all duration-1000 ease-out relative flex flex-col gap-4 pl-16 md:pl-0 md:flex-row-reverse">
                    <div class="absolute top-6 z-10 flex items-center justify-center rounded-full shadow-[0_0_15px_rgba(0,229,204,0.4)] h-5 w-5 border-2 border-[#040D14] bg-[#00E5CC] left-[11px] transform -translate-x-1/2 md:left-1/2 md:-translate-x-1/2 md:border-4">
                    </div>
                    
                    <div class="md:w-[calc(50%-3rem)] flex justify-start relative z-10">
                        <div class="w-full rounded-3xl border border-gray-800 bg-[#0a1520] p-6 md:p-8 shadow-xl transition-all hover:border-[#00E5CC]/50 hover:shadow-[0_0_35px_rgba(0,229,204,0.1)]">
                            <span class="font-mono text-xs uppercase tracking-[0.2em] text-[#00E5CC] mb-2 block">AUTOMATION & APPS</span>
                            <h3 class="text-2xl font-bold text-white mb-1">Microsoft Power Platform</h3>
                            <p class="text-sm font-mono text-gray-400 mb-4">Certified Power Platform Developer</p>
                            <p class="text-gray-300 leading-relaxed mb-6 text-sm md:text-base">Bridging the gaps between your disconnected systems. I build custom workflows, model-driven apps, and automated processes using Power Apps, Power Automate and Power Pages. It's all about eliminating manual bottlenecks and securely making your data work for you.</p>
                            <div class="flex flex-wrap gap-2 justify-start">
                                <span class="tag">Power Apps</span><span class="tag">Power Automate</span><span class="tag">Power Pages</span>
                            </div>
                        </div>
                    </div>
                    <div class="hidden md:block md:w-[calc(50%-3rem)]"></div>
                </article>

                <article class="reveal-on-scroll opacity-0 translate-y-10 transition-all duration-1000 ease-out relative flex flex-col gap-4 pl-16 md:pl-0 md:flex-row">
                    <div class="absolute top-6 z-10 flex items-center justify-center rounded-full shadow-[0_0_15px_rgba(0,229,204,0.4)] h-5 w-5 border-2 border-[#040D14] bg-[#00E5CC] left-[11px] transform -translate-x-1/2 md:left-1/2 md:-translate-x-1/2 md:border-4">
                    </div>
                    
                    <div class="md:w-[calc(50%-3rem)] md:text-right flex justify-end relative z-10">
                        <div class="w-full rounded-3xl border border-gray-800 bg-[#0a1520] p-6 md:p-8 shadow-xl transition-all hover:border-[#00E5CC]/50 hover:shadow-[0_0_35px_rgba(0,229,204,0.1)]">
                            <span class="font-mono text-xs uppercase tracking-[0.2em] text-[#00E5CC] mb-2 block">HIGH-PERFORMANCE UI</span>
                            <h3 class="text-2xl font-bold text-white mb-1">Modern Frontend Execution</h3>
                            <p class="text-sm font-mono text-gray-400 mb-4">Full-Stack Developer</p>
                            <p class="text-gray-300 leading-relaxed mb-6 text-sm md:text-base">I don't use heavy, bloated templates. I build lightning-fast, visually precise frontend architectures using Astro and Webflow, strictly styled with utility-first CSS frameworks like Tailwind. The result is a premium digital presence that loads instantly and scales flawlessly across all devices.</p>
                            <div class="flex flex-wrap gap-2 md:justify-end">
                                <span class="tag">Astro</span><span class="tag">Webflow</span><span class="tag">Tailwind</span>
                            </div>
                        </div>
                    </div>
                    <div class="hidden md:block md:w-[calc(50%-3rem)]"></div>
                </article>

                <article class="reveal-on-scroll opacity-0 translate-y-10 transition-all duration-1000 ease-out relative flex flex-col gap-4 pl-16 md:pl-0 md:flex-row-reverse">
                    <div class="absolute top-6 z-10 flex items-center justify-center rounded-full shadow-[0_0_15px_rgba(0,229,204,0.4)] h-5 w-5 border-2 border-[#040D14] bg-[#00E5CC] left-[11px] transform -translate-x-1/2 md:left-1/2 md:-translate-x-1/2 md:border-4">
                    </div>
                    
                    <div class="md:w-[calc(50%-3rem)] flex justify-start relative z-10">
                        <div class="w-full rounded-3xl border border-gray-800 bg-[#0a1520] p-6 md:p-8 shadow-xl transition-all hover:border-[#00E5CC]/50 hover:shadow-[0_0_35px_rgba(0,229,204,0.1)]">
                            <span class="font-mono text-xs uppercase tracking-[0.2em] text-[#00E5CC] mb-2 block">DATA STRUCTURES</span>
                            <h3 class="text-2xl font-bold text-white mb-1">Backend & CMS Architecture</h3>
                            <p class="text-sm font-mono text-gray-400 mb-4">Full-Stack Developer</p>
                            <p class="text-gray-300 leading-relaxed mb-6 text-sm md:text-base">A beautiful frontend needs a smart backend. I set up decoupled content architectures using Sanity, Webflow CMS, or dedicated backend engines like Xano. This gives you a secure, intuitive dashboard to manage your content and data without ever having to touch the source code.</p>
                            <div class="flex flex-wrap gap-2 justify-start">
                                <span class="tag">Sanity</span><span class="tag">Webflow CMS</span><span class="tag">Xano</span>
                            </div>
                        </div>
                    </div>
                    <div class="hidden md:block md:w-[calc(50%-3rem)]"></div>
                </article>

            </div>
        </section>
    </main>

    <Footer />
    
    <script src="../scripts/scrollReveal.js"></script>
  </body>
</html>