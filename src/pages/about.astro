---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';
import bgImage from '../images/bg.png';

const pageTitle = "Stefan Stankovic | About";
const pageDescription = "Serious Architecture. Zero Bloat. Bridging the gap between heavy enterprise systems and the modern web.";
---

<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
  </head>
  <body class="bg-[#040D14] text-white min-h-screen font-sans selection:bg-[#00E5CC] selection:text-black">
    <Navbar />

    <main class="pt-32 pb-20">
      
      <section class="container-custom mb-20 md:mb-32">
        <div class="grid items-center gap-10 lg:grid-cols-[1.05fr_0.95fr]">
          
          <article class="fade-in-up order-1 lg:order-2">
            <div class="relative mx-auto w-full max-w-md overflow-hidden rounded-3xl border border-gray-800 bg-[#08131D] p-4 shadow-xl transition-all duration-500 hover:-translate-y-1 hover:border-[#00E5CC]/50 hover:shadow-[0_0_35px_rgba(0,229,204,0.1)]">
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(0,229,204,0.08),transparent_30%)] opacity-0 transition duration-500 hover:opacity-100"></div>
              <img
                src={bgImage.src} 
                alt="Stefan Stankovic"
                class="relative h-full w-full rounded-2xl object-cover transition duration-500"
              />
            </div>
          </article>

          <article class="fade-in-up order-2 lg:order-1 text-center md:text-left" style="animation-delay: 100ms;">
            
            <p class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#00E5CC]/20 bg-[#08131D] px-4 py-2 text-xs uppercase tracking-[0.25em] text-[#00E5CC]">About Me</p>
            
            <h1 class="heading-page">
              The story so far.
            </h1>
            
            <p class="text-body mb-6 max-w-2xl mx-auto md:mx-0">
              With nearly eight years in the IT world — and the last five deeply 
              immersed in enterprise software as a Dynamics 365 F&O Developer — 
              my foundation is built on heavy business logic. 
              I've spent my career architecting complex integrations and ensuring 
              large-scale systems run flawlessly under the hood.</p>
            
            <p class="text-body mb-10 max-w-2xl mx-auto md:mx-0">
              But my curiosity doesn't stop at the backend. I actively explore the modern web space, 
              building fast, scalable platforms with Astro, Webflow, and headless CMS integrations. 
              I’m driven by continuous learning. Whether it’s adapting to AI-assisted workflows, 
              exploring new tech trends, or just writing clean code, my goal remains the same: 
              <span class="text-white font-bold">solving real problems and constantly evolving as an engineer.</span>
            </p>

            <div class="flex flex-col md:flex-row w-full max-w-xl mx-auto md:mx-0 gap-4">
              <a href="/StefanCV.pdf" download class="btn-primary w-full md:w-auto">
                <svg class="h-4 w-4 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M12 3v12" stroke-linecap="round" />
                  <path d="M8 11l4 4 4-4" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M5 19h14" stroke-linecap="round" />
                </svg>
                Download CV
              </a>
              <a href="/contact" class="btn-secondary w-full md:w-auto border border-gray-800 bg-transparent hover:border-[#00E5CC]/40 hover:bg-[#08131D]">
                Contact Me
              </a>
            </div>
          </article>
        </div>
      </section>

      <section class="section-wrapper bg-[#02080D]">
        <div class="container-custom">
          <div class="mb-16 flex flex-col gap-3 text-center lg:text-left fade-in-up">
            <span class="pill-badge self-center lg:self-start">My Approach</span>
            <h2 class="heading-section">Minimalism. Logic. Scalability.</h2>
          </div>

          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            
            <article class="card-base fade-in-up" style="animation-delay: 100ms;">
              <p class="text-xs uppercase tracking-[0.25em] text-[#00E5CC] font-bold mb-4">01</p>
              <h3 class="card-title">No Code Bloat</h3>
              <p class="text-body flex-grow">Writing clean, maintainable code without unnecessary libraries. Every single line must serve a purpose and never slow down the system.</p>
            </article>

            <article class="card-base fade-in-up" style="animation-delay: 200ms;">
              <p class="text-xs uppercase tracking-[0.25em] text-[#00E5CC] font-bold mb-4">02</p>
              <h3 class="card-title">Enterprise Architecture</h3>
              <p class="text-body flex-grow">Scalable architecture, database integrations, and business automation designed to withstand real-world enterprise loads.</p>
            </article>

            <article class="card-base fade-in-up" style="animation-delay: 300ms;">
              <p class="text-xs uppercase tracking-[0.25em] text-[#00E5CC] font-bold mb-4">03</p>
              <h3 class="card-title">Performance-First UI</h3>
              <p class="text-body flex-grow">Interfaces that don't just look visually striking, but load in milliseconds and provide a flawless user experience across all devices.</p>
            </article>
            
          </div>
        </div>
      </section>

      <section class="section-wrapper bg-[#040D14]">
        <div class="container-custom">
          <div class="rounded-3xl border border-gray-800 bg-[#08131D] p-8 md:p-12 shadow-2xl fade-in-up" style="animation-delay: 400ms;">
            <p class="pill-badge mb-8">Arsenals & Technologies</p>
            <div class="flex flex-wrap gap-3">
              <span class="tag">Dynamics 365 F&O</span>
              <span class="tag">AX 2012</span>
              <span class="tag">X++</span>
              <span class="tag">C#</span>
              <span class="tag">Power Apps</span>
              <span class="tag">Power Automate</span>
              <span class="tag">Power Pages</span>
              <span class="tag">HTML</span>
              <span class="tag">CSS</span>
              <span class="tag">JavaScript</span>
              <span class="tag">Astro</span>
              <span class="tag">Tailwind CSS</span>
              <span class="tag">Webflow</span>
              <span class="tag">TypeScript</span>
              <span class="tag">API Integrations</span>
              <span class="tag">SQL</span>
              <span class="tag">Git</span>
              <span class="tag">TFS</span>
              <span class="tag">DevOps</span>
            </div>
          </div>
        </div>
      </section>
    </main>

    <Footer />
    
    <script src="../scripts/scrollReveal.js"></script>
  </body>
</html>