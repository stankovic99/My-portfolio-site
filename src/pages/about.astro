---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import bgImage from '../images/bg.png';
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Stefan Stankovic | About</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#040D14] text-white min-h-screen font-sans selection:bg-[#00E5CC] selection:text-black overflow-x-hidden">
    <Navbar />

    <main class="pt-24 md:pt-32 pb-20">
      <section class="max-w-7xl mx-auto px-6 md:px-12 py-8 md:py-14">
        <div class="grid items-center gap-10 lg:grid-cols-[1.05fr_0.95fr]">
          
          <article class="fade-in-up order-1 lg:order-2">
            <div class="group relative mx-auto w-full max-w-md overflow-hidden rounded-3xl border border-gray-800 bg-[#08131D] p-4 shadow-[0_18px_40px_rgba(0,0,0,0.35)] transition-all duration-500 hover:-translate-y-1 hover:border-[#00E5CC]/60 hover:shadow-[0_0_35px_rgba(0,229,204,0.12)]">
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(0,229,204,0.08),transparent_30%)] opacity-0 transition duration-500 group-hover:opacity-100"></div>
              <img
                src={bgImage.src} 
                alt="Stefan Stankovic"
                class="relative h-full w-full rounded-2xl object-cover transition duration-500 group-hover:shadow-[0_0_25px_rgba(0,229,204,0.18)]"
              />
            </div>
          </article>

          <article class="fade-in-up order-2 lg:order-1 text-center md:text-left">
            <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-[#00E5CC]/20 bg-[#08131D] px-4 py-2 text-xs uppercase tracking-[0.25em] text-[#00E5CC]">About Me</p>
            <h1 class="max-w-2xl mx-auto md:mx-0 text-4xl font-black tracking-tight text-white md:text-5xl lg:text-6xl">
              Serious Architecture. Zero Bloat.
            </h1>
            <p class="mt-6 max-w-2xl mx-auto md:mx-0 text-base leading-8 text-gray-300 md:text-lg">
              I’ve spent years in the trenches of enterprise software, specifically architecting Microsoft Dynamics 365 F&O and X++ systems. I know firsthand how chaotic business logic can get, and how crucial it is to have a rock-solid infrastructure under the hood.
            </p>
            <p class="mt-4 max-w-2xl mx-auto md:mx-0 text-base leading-8 text-gray-400 md:text-lg">
              I expanded into modern web development (Astro, Tailwind, Webflow) to bridge a massive gap in the market: enterprise systems are powerful but often slow, while the modern web is fast but frequently lacks an engineering backbone. Through my agency, <span class="text-white font-semibold">Season Tech</span>, I unite these two worlds. I build platforms that are robust in the backend and lightning-fast on the frontend. No unnecessary code, no shortcuts. Just smart technology.
            </p>

            <div class="mt-10 flex flex-col md:flex-row w-full max-w-xl mx-auto md:mx-0 gap-4">
              <a href="/StefanCV.pdf" download class="flex-1 inline-flex justify-center items-center gap-2 rounded-sm border border-transparent bg-[#00E5CC] px-5 py-4 md:py-3 text-sm font-bold uppercase tracking-[0.18em] text-[#040D14] shadow-[0_0_30px_rgba(0,229,204,0.14)] transition duration-300 hover:-translate-y-0.5 hover:bg-white hover:shadow-[0_0_35px_rgba(255,255,255,0.18)]">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M12 3v12" stroke-linecap="round" />
                  <path d="M8 11l4 4 4-4" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M5 19h14" stroke-linecap="round" />
                </svg>
                Download CV
              </a>
              <a href="mailto:stefan.stankovicc99@gmail.com" class="flex-1 inline-flex justify-center items-center rounded-sm border border-gray-700 bg-transparent px-5 py-4 md:py-3 text-sm font-bold uppercase tracking-[0.18em] text-gray-100 transition duration-300 hover:border-[#00E5CC]/60 hover:bg-[#08131D] hover:text-[#00E5CC]">
                Contact Me
              </a>
            </div>
          </article>
        </div>
      </section>

      <section class="max-w-7xl mx-auto px-6 md:px-12 py-8 md:py-16">
        <div class="mb-10 flex flex-col gap-3 text-center lg:text-left">
          <p class="text-xs uppercase tracking-[0.25em] text-[#00E5CC]">My Approach</p>
          <h2 class="text-3xl font-bold tracking-tight text-white md:text-4xl">Minimalism. Logic. Scalability.</h2>
        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          <article class="rounded-3xl border border-gray-800 bg-[#0a1520] p-6 shadow-xl transition-all duration-300 hover:-translate-y-1 hover:border-[#00E5CC]/50 hover:shadow-[0_0_30px_rgba(0,229,204,0.08)]">
            <p class="text-xs uppercase tracking-[0.25em] text-[#00E5CC]">01</p>
            <h3 class="mt-3 text-2xl font-semibold text-white">No Code Bloat</h3>
            <p class="mt-3 text-gray-300">Writing clean, maintainable code without unnecessary libraries. Every single line must serve a purpose and never slow down the system.</p>
          </article>

          <article class="rounded-3xl border border-gray-800 bg-[#0a1520] p-6 shadow-xl transition-all duration-300 hover:-translate-y-1 hover:border-[#00E5CC]/50 hover:shadow-[0_0_30px_rgba(0,229,204,0.08)]">
            <p class="text-xs uppercase tracking-[0.25em] text-[#00E5CC]">02</p>
            <h3 class="mt-3 text-2xl font-semibold text-white">Enterprise Architecture</h3>
            <p class="mt-3 text-gray-300">Scalable architecture, database integrations, and business automation designed to withstand real-world enterprise loads.</p>
          </article>

          <article class="rounded-3xl border border-gray-800 bg-[#0a1520] p-6 shadow-xl transition-all duration-300 hover:-translate-y-1 hover:border-[#00E5CC]/50 hover:shadow-[0_0_30px_rgba(0,229,204,0.08)]">
            <p class="text-xs uppercase tracking-[0.25em] text-[#00E5CC]">03</p>
            <h3 class="mt-3 text-2xl font-semibold text-white">Performance-First UI</h3>
            <p class="mt-3 text-gray-300">Interfaces that don't just look visually striking, but load in milliseconds and provide a flawless user experience across all devices.</p>
          </article>
        </div>
      </section>

      <section class="max-w-7xl mx-auto px-6 md:px-12 py-8 md:py-12">
        <div class="rounded-3xl border border-gray-800 bg-[#08131D] p-6 shadow-xl md:p-8">
          <p class="text-xs uppercase tracking-[0.25em] text-[#00E5CC] mb-6">Arsenals & Technologies</p>
          <div class="flex flex-wrap gap-3">
            <span class="tag">Microsoft Dynamics 365 F&O</span>
            <span class="tag">X++</span>
            <span class="tag">Power Platform (PL-900)</span>
            <span class="tag">Power Automate</span>
            <span class="tag">Astro Framework</span>
            <span class="tag">Tailwind CSS</span>
            <span class="tag">Webflow</span>
            <span class="tag">TypeScript / JavaScript</span>
            <span class="tag">REST API Integrations</span>
            <span class="tag">SQL / Data Modeling</span>
            <span class="tag">UI/UX Principles</span>
          </div>
        </div>
      </section>
    </main>

    <Footer />

    <style is:inline>
      body {
        overflow-x: hidden !important;
        width: 100%;
      }

      .fade-in-up {
        opacity: 0;
        transform: translateY(18px);
        animation: fadeUp 0.8s ease forwards;
      }

      .fade-in-up:nth-child(2) { animation-delay: 120ms; }

      @keyframes fadeUp {
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .tag {
        display: inline-flex;
        align-items: center;
        border: 1px solid rgba(148, 163, 184, 0.35);
        background: rgba(255, 255, 255, 0.04);
        border-radius: 9999px;
        padding: 0.4rem 0.9rem;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: #cbd5e1;
        transition: all 0.3s ease;
      }
      
      .tag:hover {
        border-color: rgba(0, 229, 204, 0.6);
        color: #fff;
        background: rgba(0, 229, 204, 0.1);
      }
    </style>
  </body>
</html>