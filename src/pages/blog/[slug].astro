---
import { getCollection, type CollectionEntry, render } from "astro:content";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import BaseHead from "../../components/BaseHead.astro";
import "../../styles/global.css";

// Definišemo TypeScript interfejs za Props ove komponente
export interface Props {
    entry: CollectionEntry<"blog">;
}

// Generisanje putanja
export async function getStaticPaths() {
    const blog = await getCollection("blog");
    return blog.map((entry) => ({
        params: { slug: entry.id.replace(/\.md$/, "") },
        props: { entry },
    }));
}

// Sada TypeScript (i VS Code) tačno zna šta je "entry"
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<html lang="en" class="scroll-smooth">
    <head>
        <BaseHead
            title={`${entry.data.title} | Stefan Stankovic`}
            description={entry.data.description}
        />
    </head>
    <body
        class="bg-[#040D14] text-white min-h-screen font-sans selection:bg-[#00E5CC] selection:text-black overflow-x-hidden"
    >
        <Navbar />

        <main class="pt-32 pb-20">
            <!-- HEADER PROJEKTA (Uvek levo poravnanje) -->
            <header
                class="container-custom mb-16 text-left border-b border-gray-800 pb-12 pt-4"
            >
                <!-- Back Button -->
                <a
                    href="/portfolio"
                    class="inline-flex items-center gap-2 font-mono text-sm text-gray-500 hover:text-[#00E5CC] transition-colors mb-10 fade-in-up"
                >
                    <svg
                        class="h-4 w-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg
                    >
                    Back to Portfolio
                </a>

                <!-- SADRŽAJ (Proširen za moderniji prikaz) -->
                <h1 class="text-5xl font-bold mt-8 mb-2">{entry.data.title}</h1>
                <p class="text-[#00E5CC] mb-8">
                    {entry.data.date.toLocaleDateString()}
                </p>
                <article class="prose prose-invert max-w-4xl">
                    <Content />
                </article>
            </header>
        </main>

        <Footer />
    </body>
</html>
