---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';

const pageTitle = "Stefan Stankovic | Contact";
const pageDescription = "Let's build something solid. Get in touch to discuss enterprise architecture and modern web solutions.";
---

<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
  </head>
  <body class="bg-[#040D14] text-white min-h-screen font-sans selection:bg-[#00E5CC] selection:text-black">
    <Navbar />

    <main class="pt-32 pb-20">
      
      <section class="container-custom mb-16">
        <div class="text-center lg:text-left max-w-4xl mx-auto lg:mx-0 fade-in-up">
          <div class="pill-badge">
            Contact
          </div>
          <h1 class="heading-page">
            Ready to discuss your ideas?
          </h1>
          <p class="text-body max-w-2xl">
            I'm always open to discussing new challenges. Send over your requirements, timeline, or technical bottlenecks, and let's figure out the best engineering approach.
          </p>
        </div>
      </section>

      <section class="container-custom">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-20">
          
          <div class="lg:col-span-5 fade-in-up" style="animation-delay: 150ms;">
            <h2 class="heading-section mb-8">Direct Contact</h2>
            
            <div class="space-y-8">
              <div class="group flex items-start gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-gray-800 bg-[#08131D] text-[#00E5CC] group-hover:border-[#00E5CC]/50 transition-colors">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <p class="font-mono text-xs text-gray-500 uppercase tracking-widest mb-1">Email</p>
                  <a href="mailto:stefan.stankovicc99@gmail.com" class="text-base md:text-lg text-gray-300 hover:text-[#00E5CC] transition-colors break-all">stefan.stankovicc99@gmail.com</a>
                </div>
              </div>

              <div class="group flex items-start gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-gray-800 bg-[#08131D] text-[#00E5CC] group-hover:border-[#00E5CC]/50 transition-colors">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <p class="font-mono text-xs text-gray-500 uppercase tracking-widest mb-1">Phone</p>
                  <a href="tel:+38976206664" class="text-base md:text-lg text-gray-300 hover:text-[#00E5CC] transition-colors">+389 76 206 664</a>
                </div>
              </div>

              <div class="group flex items-start gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-gray-800 bg-[#08131D] text-[#00E5CC] group-hover:border-[#00E5CC]/50 transition-colors">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <p class="font-mono text-xs text-gray-500 uppercase tracking-widest mb-1">Location</p>
                  <p class="text-base md:text-lg text-gray-300">Skopje, North Macedonia</p>
                </div>
              </div>
            </div>

            <div class="mt-12 pt-8 border-t border-gray-800">
              <p class="font-mono text-xs text-gray-500 uppercase tracking-widest mb-4">Professional Network</p>
              <div class="flex gap-4">
                <a href="https://www.linkedin.com/in/stefan-stankovic-6926aa23a/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-[#08131D] border border-gray-800 text-gray-400 hover:border-[#00E5CC] hover:text-[#00E5CC] transition-all">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </a>
                <a href="https://github.com/stankovic99" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-[#08131D] border border-gray-800 text-gray-400 hover:border-[#00E5CC] hover:text-[#00E5CC] transition-all">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                </a>
              </div>
            </div>
          </div>

          <div class="lg:col-span-7 fade-in-up" style="animation-delay: 200ms;">
            <div class="rounded-3xl border border-gray-800 bg-[#08131D] p-8 md:p-12 shadow-[0_18px_40px_rgba(0,0,0,0.35)]">
              
              <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="flex flex-col gap-6 relative">
                <input type="hidden" name="access_key" value="bf5fb5c5-6ad9-4ae7-8d91-812e7237b598">
                <input type="hidden" name="subject" value="New Contact from Portfolio Website">
                <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

                <div class="flex flex-col gap-6">
                  <div class="flex flex-col gap-2">
                    <label for="name" class="font-mono text-xs text-gray-400 uppercase tracking-widest">Name</label>
                    <input type="text" id="name" name="name" required placeholder="Marcus Vance" class="rounded-xl border border-gray-700 bg-[#040D14] px-5 py-4 text-white placeholder-gray-600 focus:border-[#00E5CC] focus:outline-none focus:ring-1 focus:ring-[#00E5CC] transition-colors" />
                  </div>
                  
                  <div class="flex flex-col gap-2">
                    <label for="email" class="font-mono text-xs text-gray-400 uppercase tracking-widest">Email</label>
                    <input type="email" id="email" name="email" required placeholder="m.vance@company.com" class="rounded-xl border border-gray-700 bg-[#040D14] px-5 py-4 text-white placeholder-gray-600 focus:border-[#00E5CC] focus:outline-none focus:ring-1 focus:ring-[#00E5CC] transition-colors" />
                  </div>
                </div>

                <div class="flex flex-col gap-2 mt-2">
                  <label for="message" class="font-mono text-xs text-gray-400 uppercase tracking-widest">Message</label>
                  <textarea id="message" name="message" rows="6" required placeholder="Briefly describe your project, timeline, or the technical bottlenecks you're currently facing.." class="rounded-xl border border-gray-700 bg-[#040D14] px-5 py-4 text-white placeholder-gray-600 focus:border-[#00E5CC] focus:outline-none focus:ring-1 focus:ring-[#00E5CC] transition-colors resize-none"></textarea>
                </div>

                <button type="submit" class="mt-4 w-full md:w-auto inline-flex justify-center items-center gap-2 rounded-sm border border-transparent bg-[#00E5CC] px-8 py-4 text-sm font-bold uppercase tracking-[0.18em] text-[#040D14] shadow-[0_0_30px_rgba(0,229,204,0.14)] transition duration-300 hover:-translate-y-0.5 hover:bg-white hover:shadow-[0_0_35px_rgba(255,255,255,0.18)] disabled:opacity-50 disabled:cursor-not-allowed">
                  <span>Send Message</span>
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                </button>
                
                <div id="success-message" class="hidden absolute inset-0 bg-[#08131D] flex flex-col items-center justify-center z-10 transition-opacity duration-300">
                  <div class="h-16 w-16 bg-[#00E5CC]/10 text-[#00E5CC] rounded-full flex items-center justify-center mb-4">
                    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <h3 class="text-xl font-sans font-bold text-white mb-2">Message Sent</h3>
                  <p class="font-mono text-sm text-gray-400">I'll get back to you shortly.</p>
                </div>

              </form>
            </div>
          </div>

        </div>
      </section>

    </main>

    <Footer />

    <script src="../scripts/contactForm.js"></script>
  </body>
</html>