---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';
import bgImage from '../images/bg.png';
import skyPreview from '../images/SkyMockup.png';
import bendPort from '../images/StefanMockup.png';

const pageTitle = "Stefan Stankovic | Tech Architect";
const pageDescription = "Enterprise architecture and high-performance web systems.";
---

<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
  </head>
  <body class="bg-[#040D14] text-white min-h-screen font-sans selection:bg-[#00E5CC] selection:text-black overflow-x-hidden">
    
    <Navbar />

    <main class="relative container-custom pt-32 pb-16 md:pt-40 md:pb-24 flex flex-col md:flex-row items-center justify-center md:justify-between min-h-[100svh] w-full">

      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_80%_80%_at_50%_50%,#000_20%,transparent_100%)] z-0 pointer-events-none"></div>
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 md:translate-x-0 md:left-auto md:right-10 w-[300px] h-[300px] bg-[#00E5CC]/10 rounded-full blur-[100px] z-0 pointer-events-none"></div>

      <div class="w-full md:w-3/5 z-10 flex flex-col items-center md:items-start text-center md:text-left relative">

        <div class="flex gap-4 mb-8 reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700">
          <div class="inline-flex items-center space-x-2 border border-[#00E5CC]/30 bg-[#00E5CC]/5 rounded-full px-4 py-1.5">
            <span class="w-2 h-2 rounded-full bg-[#00E5CC]"></span>
            <span class="text-xs font-sans font-semibold text-gray-300 tracking-wider uppercase">Enterprise Engineer & Architect</span>
          </div>
          <a href="https://www.linkedin.com/in/stefan-stankovic-6926aa23a/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center space-x-2 border border-blue-500/30 bg-blue-500/5 hover:bg-blue-500/10 rounded-full px-4 py-1.5 transition-colors">
            <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 24 24"><path d="M22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0zM7.06 20.45H3.56V9h3.5v11.45zM5.31 7.48c-1.13 0-2.05-.92-2.05-2.05 0-1.13.92-2.05 2.05-2.05 1.13 0 2.05.92 2.05 2.05 0 1.13-.92 2.05-2.05 2.05zM20.45 20.45h-3.5v-5.58c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.68h-3.5V9h3.36v1.56h.05c.47-.89 1.62-1.83 3.33-1.83 3.57 0 4.23 2.35 4.23 5.4v6.32z"/></svg>
            <span class="text-xs font-sans font-semibold text-blue-400 tracking-wider uppercase">LinkedIn</span>
          </a>
        </div>

        <h1 class="reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700 delay-100 heading-primary mb-6">
          No Code Bloat. <br />
          <span class="font-serif italic font-normal tracking-normal text-[#00E5CC]">Just Smart Tech.</span>
        </h1>

        <p class="reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700 delay-200 text-body max-w-xl mb-10">
          I build scalable infrastructure and high-performance web systems. 
          Whether it's enterprise data modeling or conversion-focused platforms, I engineer solutions that simply don't break.
        </p>

        <div class="reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700 delay-300 flex flex-col sm:flex-row items-center justify-center md:justify-start gap-4 mt-8 w-full">
          <a href="#portfolio" class="btn-primary">
            VIEW INFRASTRUCTURE
          </a>
          <a href="#services" class="btn-secondary">
            EXPLORE SERVICES <span>→</span>
          </a>
        </div>

      </div>

      <div class="hidden md:flex w-2/5 justify-end items-end relative min-h-[400px] lg:min-h-[500px] reveal-on-scroll opacity-0 translate-x-10 transition-all duration-1000 delay-500">
        <img 
          src={bgImage.src} 
          alt="Stefan Stankovic" 
          class="w-4/5 lg:w-3/4 object-contain relative z-10 drop-shadow-2xl"
        />
        <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-[#040D14] to-transparent z-20 pointer-events-none"></div>
      </div>

    </main> 

    <section class="w-full bg-[#02080D] border-y border-gray-800/50 py-5 overflow-hidden relative pause-on-hover select-none">
      <div class="absolute inset-y-0 left-0 w-16 md:w-40 bg-gradient-to-r from-[#02080D] to-transparent z-10 pointer-events-none"></div>
      <div class="absolute inset-y-0 right-0 w-16 md:w-40 bg-gradient-to-l from-[#02080D] to-transparent z-10 pointer-events-none"></div>

      <div class="animate-marquee">
        <ul class="flex items-center justify-center space-x-8 md:space-x-12 px-4 md:px-6 m-0">
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Dynamics 365 F&O</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">X++ Architecture</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Power Platform</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Webflow Engineering</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Tailwind CSS</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">API Integrations</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Enterprise Data Modeling</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
        </ul>

        <ul class="flex items-center justify-center space-x-8 md:space-x-12 px-4 md:px-6 m-0" aria-hidden="true">
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Dynamics 365 F&O</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">X++ Architecture</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Power Platform</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Webflow Engineering</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Tailwind CSS</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">API Integrations</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Enterprise Data Modeling</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
        </ul>
      </div>
    </section>

    <section id="about" class="section-wrapper bg-[#040D14]">
      <div class="container-custom">
        
        <div class="text-center mb-16 md:mb-24 reveal-on-scroll opacity-0 translate-y-10 transition-all duration-1000 ease-out">
          <h2 class="heading-section mb-6">
            Stop losing money on <br/>
            <span class="font-serif italic font-normal text-red-500 tracking-normal">disconnected tech.</span>
          </h2>
          <p class="text-body md:text-lg max-w-2xl mx-auto">
            I provide the technical execution to bridge the gap between heavy enterprise systems and high-performance web platforms.
          </p>
        </div>

        <div class="relative w-full max-w-5xl mx-auto reveal-on-scroll opacity-0 translate-y-10 transition-all duration-1000 delay-200 ease-out">
          <div class="flex flex-col md:flex-row items-center justify-between gap-6 md:gap-0">
            
            <div class="z-10 w-full md:w-[35%] border border-gray-800 bg-[#08131D] p-8 text-center shadow-2xl relative group hover:border-[#00E5CC]/30 transition-colors duration-300 rounded-sm">
              <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-sm bg-[#040D14] border border-gray-800 text-[#00E5CC] group-hover:bg-[#00E5CC]/10 transition-colors duration-300">
                <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/></svg>
              </div>
              <h3 class="font-sans font-bold text-white text-xl mb-3 uppercase tracking-wider">Enterprise Backend</h3>
              <p class="font-mono text-sm text-gray-500 leading-relaxed mb-4">Executing precise logic and database relations as the technical engine of enterprise teams.</p>
              <div class="inline-flex items-center gap-2 border-t border-gray-800 pt-4">
                <span class="tech-badge-sm">D365 F&O</span>
                <span class="tech-badge-sm">X++</span>
              </div>
            </div>

            <div class="hidden md:flex flex-1 items-center justify-center relative h-10 w-full px-4">
              <div class="absolute h-[1px] w-full bg-gradient-to-r from-gray-800 via-[#00E5CC] to-gray-800 opacity-50"></div>
              <div class="z-10 flex items-center justify-center rounded-sm border border-[#00E5CC]/50 bg-[#040D14] px-5 py-2 shadow-[0_0_20px_rgba(0,229,204,0.1)] relative">
                <div class="absolute inset-0 rounded-sm border border-[#00E5CC] animate-ping opacity-20"></div>
                <span class="font-sans font-bold text-xs text-white uppercase tracking-widest relative z-10 flex items-center gap-2">
                    <svg class="h-3 w-3 text-[#00E5CC]" fill="currentColor" viewBox="0 0 24 24"><path d="M21 13v10h-21v-19h12v2h-10v15h17v-8h2zm3-12h-10.988l4.035 4-6.977 7.07 2.828 2.828 6.977-7.07 4.125 4.172v-11z"/></svg>
                    Integration
                </span>
              </div>
            </div>

            <div class="md:hidden flex h-16 w-16 items-center justify-center text-[#00E5CC]">
              <svg class="h-8 w-8 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
            </div>

            <div class="z-10 w-full md:w-[35%] border border-gray-800 bg-[#08131D] p-8 text-center shadow-2xl relative group hover:border-[#00E5CC]/30 transition-colors duration-300 rounded-sm">
              <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-sm bg-[#040D14] border border-gray-800 text-[#00E5CC] group-hover:bg-[#00E5CC]/10 transition-colors duration-300">
                <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
              </div>
              <h3 class="font-sans font-bold text-white text-xl mb-3 uppercase tracking-wider">Modern Frontend</h3>
              <p class="font-mono text-sm text-gray-500 leading-relaxed mb-4">Building fast, clean UI/UX platforms structured to securely connect with backends.</p>
              <div class="inline-flex items-center gap-2 border-t border-gray-800 pt-4">
                <span class="tech-badge-sm">Astro</span>
                <span class="tech-badge-sm">Tailwind</span>
              </div>
            </div>

          </div>
        </div>

      </div>
    </section>
    
    <section id="services" class="section-wrapper bg-[#02080D]">
      <div class="container-custom">
        
        <div class="text-center md:text-left mb-16 reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700 ease-out">
          <span class="subheading-tag">Core Competencies</span>
          <h2 class="heading-section">
            Systems I Build.
          </h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-10 auto-rows-fr">
          
          <div class="card-base reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700 delay-100 ease-out">
            <svg class="w-10 h-10 lg:w-12 lg:h-12 text-gray-500 group-hover:text-[#00E5CC] transition-colors mb-6 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path></svg>
            
            <h3 class="card-title">Dynamics 365 F&O</h3>
            
            <p class="font-sans text-gray-300 md:text-gray-400 text-base lg:text-lg leading-relaxed mb-8 flex-grow">
              Architecting deep backend logic, executing complex data migrations, and developing robust X++ solutions for enterprise environments.
            </p>
            
            <ul class="text-sm lg:text-base text-gray-400 md:text-gray-500 space-y-3 font-mono tracking-wide mt-auto shrink-0">
              <li class="flex items-center"><span class="text-[#00E5CC] mr-3 font-bold">></span> X++ Development</li>
              <li class="flex items-center"><span class="text-[#00E5CC] mr-3 font-bold">></span> SysOperation Framework</li>
              <li class="flex items-center"><span class="text-[#00E5CC] mr-3 font-bold">></span> Relational Databases</li>
            </ul>
          </div>

          <div class="card-base reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700 delay-200 ease-out">
            <svg class="w-10 h-10 lg:w-12 lg:h-12 text-gray-500 group-hover:text-[#00E5CC] transition-colors mb-6 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
            
            <h3 class="card-title">Web Architecture</h3>
            
            <p class="font-sans text-gray-300 md:text-gray-400 text-base lg:text-lg leading-relaxed mb-8 flex-grow">
              Translating premium UI/UX designs into lightning-fast, scalable frontend platforms using modern frameworks and strict CSS methodologies.
            </p>
            
            <ul class="text-sm lg:text-base text-gray-400 md:text-gray-500 space-y-3 font-mono tracking-wide mt-auto shrink-0">
              <li class="flex items-center"><span class="text-[#00E5CC] mr-3 font-bold">></span> Tailwind CSS Logic</li>
              <li class="flex items-center"><span class="text-[#00E5CC] mr-3 font-bold">></span> Webflow & Astro</li>
              <li class="flex items-center"><span class="text-[#00E5CC] mr-3 font-bold">></span> Frontend Integration</li>
            </ul>
          </div>

          <div class="card-base reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700 delay-300 ease-out">
            <svg class="w-10 h-10 lg:w-12 lg:h-12 text-gray-500 group-hover:text-[#00E5CC] transition-colors mb-6 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            
            <h3 class="card-title">Power Platform</h3>
            
            <p class="font-sans text-gray-300 md:text-gray-400 text-base lg:text-lg leading-relaxed mb-8 flex-grow">
              Eliminating manual bottlenecks by bridging disconnected systems. Building custom workflows and automated processes that scale.
            </p>
            
            <ul class="text-sm lg:text-base text-gray-400 md:text-gray-500 space-y-3 font-mono tracking-wide mt-auto shrink-0">
              <li class="flex items-center"><span class="text-[#00E5CC] mr-3 font-bold">></span> Process Automation</li>
              <li class="flex items-center"><span class="text-[#00E5CC] mr-3 font-bold">></span> API Connections</li>
              <li class="flex items-center"><span class="text-[#00E5CC] mr-3 font-bold">></span> Model-Driven Apps</li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <section id="portfolio" class="section-wrapper bg-[#040D14]">
      <div class="container-custom">

        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700 ease-out">
          <div>
            <span class="subheading-tag">Proof of Work</span>
            <h2 class="heading-section">
              Engineered Platforms.
            </h2>
          </div>
          <a href="/portfolio" class="font-sans text-sm font-bold text-gray-400 hover:text-[#00E5CC] uppercase tracking-widest transition-colors mt-6 md:mt-0 flex items-center gap-2">
            View All Projects <span>→</span>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 auto-rows-fr">

          <a href="http://skyrestaurant.mk/" target="_blank" rel="noopener noreferrer" class="h-full reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700 delay-100 ease-out group cursor-pointer flex flex-col focus:outline-none">
            
            <div class="relative w-full aspect-video overflow-hidden rounded-sm border border-gray-800/80 bg-[#02080D] mb-6">
              <img 
                src={skyPreview.src} 
                alt="Sky Restaurant System" 
                class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-[#00E5CC]/0 group-hover:bg-[#00E5CC]/10 transition-colors duration-500"></div>
            </div>
            
            <h3 class="card-title">Sky Restaurant System</h3>
            <p class="text-body flex-grow mb-6">
              Dynamic data fetching via structured JSON source. Prioritized fast load times and clean frontend architecture.
            </p>
            
            <div class="flex flex-wrap gap-3 mt-auto shrink-0">
              <span class="tech-badge">Tailwind CSS</span>
              <span class="tech-badge">JSON API</span>
            </div>
          </a>

          <a href="https://stefanslavkovic.webflow.io/" target="_blank" rel="noopener noreferrer" class="h-full reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700 delay-200 ease-out group cursor-pointer flex flex-col focus:outline-none">
            
            <div class="relative w-full aspect-video overflow-hidden rounded-sm border border-gray-800/80 bg-[#02080D] mb-6">
              <img 
                src={bendPort.src} 
                alt="Advanced Webflow Platform" 
                class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-[#00E5CC]/0 group-hover:bg-[#00E5CC]/10 transition-colors duration-500"></div>
            </div>
            
            <h3 class="card-title">Advanced Webflow Platform</h3>
            <p class="text-body flex-grow mb-6">
              Custom architecture integrating Client-First naming conventions and scalable CMS solutions for enterprise needs.
            </p>
            
            <div class="flex flex-wrap gap-3 mt-auto shrink-0">
              <span class="tech-badge">Webflow</span>
              <span class="tech-badge">GSAP</span>
            </div>
          </a>

        </div>

      </div>
    </section>

    <section id="contact" class="section-wrapper bg-[#02080D] flex flex-col items-center justify-center text-center">
      
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] md:w-[500px] md:h-[500px] bg-[#00E5CC]/5 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="max-w-4xl mx-auto px-6 relative z-10 reveal-on-scroll opacity-0 translate-y-10 transition-all duration-1000 ease-out">
        
        <h2 class="heading-primary mb-6">
          <span class="text-white block">Let's build a system</span>
          <span class="text-gray-600 block">that scales.</span>
        </h2>

        <p class="text-body mb-12">
          Zero templates. No bloated code. Just pure engineering.
        </p>

        <a href="/contact" class="btn-primary shadow-[0_0_30px_rgba(0,229,204,0.2)] hover:shadow-[0_0_40px_rgba(255,255,255,0.4)]">
          INITIATE CONTACT
        </a>

      </div>
    </section>

    <Footer />

  <script src="../scripts/scrollReveal.js"></script>
  </body>
</html>