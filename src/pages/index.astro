---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';
import bgImage from '../images/bg.png';
import skyPreview from '../images/SkyMockup.png';
import bendPort from '../images/StefanMockup.png';

const pageTitle = "Stefan Stankovic | Tech Architect";
const pageDescription = "Enterprise architecture and high-performance web systems.";
---

<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
  </head>
  <body class="bg-[#040D14] text-white min-h-screen font-sans selection:bg-[#00E5CC] selection:text-black overflow-x-hidden">
    
    <Navbar />

    <main class="relative container-custom pt-32 pb-16 md:pt-40 md:pb-24 flex flex-col md:flex-row items-center justify-center md:justify-between min-h-[100svh] w-full">

      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_80%_80%_at_50%_50%,#000_20%,transparent_100%)] z-0 pointer-events-none"></div>
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 md:translate-x-0 md:left-auto md:right-10 w-[300px] h-[300px] bg-[#00E5CC]/10 rounded-full blur-[100px] z-0 pointer-events-none"></div>

      <div class="w-full md:w-3/5 z-10 flex flex-col items-center md:items-start text-center md:text-left relative">

        <div class="flex gap-4 mb-8 reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700">
          <div class="inline-flex items-center space-x-2 border border-[#00E5CC]/30 bg-[#00E5CC]/5 rounded-full px-4 py-1.5">
            <span class="w-2 h-2 rounded-full bg-[#00E5CC]"></span>
            <span class="text-xs font-sans font-semibold text-gray-300 tracking-wider uppercase">Enterprise Engineer & Architect</span>
          </div>
          <a href="https://www.linkedin.com/in/stefan-stankovic-6926aa23a/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center space-x-2 border border-blue-500/30 bg-blue-500/5 hover:bg-blue-500/10 rounded-full px-4 py-1.5 transition-colors">
            <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 24 24"><path d="M22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0zM7.06 20.45H3.56V9h3.5v11.45zM5.31 7.48c-1.13 0-2.05-.92-2.05-2.05 0-1.13.92-2.05 2.05-2.05 1.13 0 2.05.92 2.05 2.05 0 1.13-.92 2.05-2.05 2.05zM20.45 20.45h-3.5v-5.58c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.68h-3.5V9h3.36v1.56h.05c.47-.89 1.62-1.83 3.33-1.83 3.57 0 4.23 2.35 4.23 5.4v6.32z"/></svg>
            <span class="text-xs font-sans font-semibold text-blue-400 tracking-wider uppercase">LinkedIn</span>
          </a>
        </div>

        <h1 class="reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700 delay-100 heading-primary mb-6">
          No Code Bloat. <br />
          <span class="font-serif italic font-normal tracking-normal text-[#00E5CC]">Just Smart Tech.</span>
        </h1>

        <p class="reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700 delay-200 text-body max-w-xl mb-10">
          I'm a Dynamics 365 F&O, Power Platform and Web developer. I bridge the gap between heavy ERP business processes and fast, modern frontends.
          No bloated templates—just clean code and systems that refuse to break.
        </p>

        <div class="reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700 delay-300 flex flex-col sm:flex-row items-center justify-center md:justify-start gap-4 mt-8 w-full">
          <a href="#portfolio" class="btn-primary">
            View Case Studies
          </a>
          <a href="/contact" class="btn-secondary">
            Discuss Your Project
          </a>
        </div>

      </div>

      <div class="hidden md:flex w-2/5 justify-end items-end relative min-h-[400px] lg:min-h-[500px] reveal-on-scroll opacity-0 translate-x-10 transition-all duration-1000 delay-500">
        <img 
          src={bgImage.src} 
          alt="Stefan Stankovic" 
          class="w-4/5 lg:w-3/4 object-contain relative z-10 drop-shadow-2xl"
        />
        <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-[#040D14] to-transparent z-20 pointer-events-none"></div>
      </div>

    </main> 

    <section class="w-full bg-[#02080D] border-y border-gray-800/50 py-5 overflow-hidden relative pause-on-hover select-none">
      <div class="absolute inset-y-0 left-0 w-16 md:w-40 bg-gradient-to-r from-[#02080D] to-transparent z-10 pointer-events-none"></div>
      <div class="absolute inset-y-0 right-0 w-16 md:w-40 bg-gradient-to-l from-[#02080D] to-transparent z-10 pointer-events-none"></div>

      <div class="animate-marquee">
        <ul class="flex items-center justify-center space-x-8 md:space-x-12 px-4 md:px-6 m-0">
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">D365 F&O</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">X++</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Power Platform</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Webflow Engineering</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Tailwind CSS</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">API Integrations</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Enterprise Data Modeling</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
        </ul>

        <ul class="flex items-center justify-center space-x-8 md:space-x-12 px-4 md:px-6 m-0" aria-hidden="true">
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">D365 F&O</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">X++</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Power Platform</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Webflow Engineering</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Tailwind CSS</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">API Integrations</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
          <li class="font-mono text-gray-500 text-sm md:text-base tracking-widest uppercase whitespace-nowrap">Enterprise Data Modeling</li>
          <li class="text-[#00E5CC] text-xl leading-none">•</li>
        </ul>
      </div>
    </section>

    <section class="container-custom py-24 ">
  
      <div class="text-center max-w-3xl mx-auto mb-20 fade-in-up">
        <h2 class="text-4xl md:text-5xl font-bold mb-6 font-sans">
          Three Disciplines.<br/>
          <span class="text-[#00E5CC] italic font-serif font-light">One Engineering Standard.</span>
        </h2>
        <p class="text-gray-400 text-lg font-mono leading-relaxed">
          I don't just build websites or configure apps; I architect systems. With deep roots in enterprise ERP logic, I bring heavy-duty engineering discipline to the Power Platform and the modern web. I build systems that simply do not break.
        </p>
      </div>

      <div class="flex flex-col lg:flex-row items-stretch justify-center gap-0 relative w-full fade-in-up" style="animation-delay: 200ms;">

        <div class="w-full lg:w-1/3 flex flex-col text-center p-8 bg-[#0a151f] border border-gray-800 rounded-2xl relative group hover:border-[#00E5CC] transition-colors duration-300">
          <div class="mx-auto w-14 h-14 rounded-xl bg-[#00E5CC]/10 flex items-center justify-center text-[#00E5CC] mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-4 text-white">ENTERPRISE ERP LOGIC</h3>
          <p class="text-sm text-gray-400 font-mono mb-8 flex-grow leading-relaxed">
            Writing robust, hyper-precise X++ business logic for large-scale Dynamics 365 environments. I understand complex data modeling and system stability from the inside out.
          </p>
          <div class="text-[#00E5CC] font-bold text-xs tracking-widest uppercase mt-auto">
            D365 F&O • X++
          </div>
        </div>

        <div class="flex flex-col lg:flex-row items-center justify-center shrink-0 py-4 lg:py-0 lg:px-4">
          <div class="w-px h-10 lg:w-10 lg:h-px bg-gray-800 relative group-hover:bg-[#00E5CC] transition-colors duration-500">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-[#00E5CC] shadow-[0_0_12px_#00E5CC]"></div>
          </div>
        </div>

        <div class="w-full lg:w-1/3 flex flex-col text-center p-8 bg-[#0a151f] border border-gray-800 rounded-2xl relative group hover:border-[#00E5CC] transition-colors duration-300 mt-0">
          <div class="mx-auto w-14 h-14 rounded-xl bg-[#00E5CC]/10 flex items-center justify-center text-[#00E5CC] mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-4 text-white">POWER PLATFORM</h3>
          <p class="text-sm text-gray-400 font-mono mb-8 flex-grow leading-relaxed">
            Executing developer-grade custom workflows, automated logic, and enterprise-scale model-driven apps to eliminate bottlenecks and securely bridge disconnected systems.
          </p>
          <div class="text-[#00E5CC] font-bold text-xs tracking-widest uppercase mt-auto">
            Automate • Apps • Pages
          </div>
        </div>

        <div class="flex flex-col lg:flex-row items-center justify-center shrink-0 py-4 lg:py-0 lg:px-4">
          <div class="w-px h-10 lg:w-10 lg:h-px bg-gray-800 relative group-hover:bg-[#00E5CC] transition-colors duration-500">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-[#00E5CC] shadow-[0_0_12px_#00E5CC]"></div>
          </div>
        </div>

        <div class="w-full lg:w-1/3 flex flex-col text-center p-8 bg-[#0a151f] border border-gray-800 rounded-2xl relative group hover:border-[#00E5CC] transition-colors duration-300 mt-0">
          <div class="mx-auto w-14 h-14 rounded-xl bg-[#00E5CC]/10 flex items-center justify-center text-[#00E5CC] mb-6">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-4 text-white">HIGH-PERFORMANCE WEB</h3>
          <p class="text-sm text-gray-400 font-mono mb-8 flex-grow leading-relaxed">
            Translating strict architectural standards into the modern web. I build lightning-fast, highly converting platforms using clean structures and zero-latency UI/UX.
          </p>
          <div class="text-[#00E5CC] font-bold text-xs tracking-widest uppercase mt-auto">
            Astro • Webflow • Tailwind
          </div>
        </div>

      </div>
    </section>

    <section id="portfolio" class="section-wrapper bg-[#040D14]  relative overflow-hidden">
      <div class="container-custom">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[#00E5CC] opacity-[0.03] blur-[120px] rounded-full pointer-events-none"></div>
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 reveal-on-scroll opacity-0 translate-y-10 transition-all duration-700 ease-out">
          <div>
            <span class="subheading-tag">Proof of Work</span>
            <h2 class="heading-section">
              Engineered Platforms.
            </h2>
          </div>
          <a href="/portfolio" class="font-sans text-sm font-bold text-gray-400 hover:text-[#00E5CC] uppercase tracking-widest transition-colors mt-6 md:mt-0 flex items-center gap-2">
            View All Projects <span>→</span>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 auto-rows-fr">

          <a href="/projects/sky-restaurant" class="card-base group relative fade-in-up" style="animation-delay: 150ms;">
            <div>
              <div class="mb-6 aspect-video w-full overflow-hidden rounded-xl border border-gray-800 bg-[#040D14] relative">
                <div class="absolute inset-0 bg-cover bg-center group-hover:scale-105 transition-transform duration-700" style={`background-image: url('${skyPreview.src}')`}></div>
              </div>
              <h3 class="card-title">Sky Restaurant & Pool Bar</h3>
              <p class="text-gray-400 leading-relaxed text-sm mb-6">
                Premium digital presence with full English/Macedonian localization and dynamic JSON menu architecture for effortless management.
              </p>
            </div>
            <div class="flex flex-wrap gap-2">
              <span class="tag">Full-Stack</span><span class="tag">JSON Architecture</span><span class="tag">i18n</span>
            </div>
          </a>

          <a href="/projects/stefan-slavkovic" class="card-base group relative fade-in-up" style="animation-delay: 150ms;">
            <div>
              <div class="mb-6 aspect-video w-full overflow-hidden rounded-xl border border-gray-800 bg-[#040D14] relative">
                <div class="absolute inset-0 bg-cover bg-center group-hover:scale-105 transition-transform duration-700" style={`background-image: url('${bendPort.src}')`}></div>
              </div>
              <h3 class="card-title">Visual Artist Portfolio</h3>
              <p class="text-gray-400 leading-relaxed text-sm mb-6">
                Custom Webflow architecture tailored for high-resolution graphic assets. Engineered with optimized interactions and dynamic image sliders.
              </p>
            </div>
            <div class="flex flex-wrap gap-2">
              <span class="tag">Webflow</span><span class="tag">CMS</span><span class="tag">INTERACTIONS</span>
            </div>
          </a>

        </div>

      </div>
    </section>

    <section id="contact" class="section-wrapper bg-[#02080D] flex flex-col items-center justify-center text-center">
      
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] md:w-[500px] md:h-[500px] bg-[#00E5CC]/5 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="max-w-4xl mx-auto px-6 relative z-10 reveal-on-scroll opacity-0 translate-y-10 transition-all duration-1000 ease-out">
        
        <h2 class="heading-primary mb-6">
          <span class="text-white block">Let's build a system</span>
          <span class="text-gray-600 block">that scales.</span>
        </h2>
        
        <p class="text-body mb-12">
          Zero templates. No bloated code. Just pure engineering.
        </p>

        <a href="/contact" class="btn-primary shadow-[0_0_30px_rgba(0,229,204,0.2)] hover:shadow-[0_0_40px_rgba(255,255,255,0.4)]">
          INITIATE CONTACT
        </a>

      </div>
    </section>

    <Footer />

  <script src="../scripts/scrollReveal.js"></script>
  </body>
</html>